#!/bin/bash
#
# Lima Pipeline - Shell Wrapper
#
# PacBio demultiplexing pipeline for HiFi amplicon sequencing data
#
# Usage:
#   ./lima --dir_data /path/to/bams --dir_out /path/to/results [options]
#
# Examples:
#   ./lima --dir_data ~/data/bam --dir_out ~/results --barcode_ref ~/refs/barcodes.fasta
#   ./lima --dir_data ~/data/bam --dir_out ~/results --barcode_ref ~/refs/barcodes.fasta --biosample_csv ~/refs/biosample.csv
#   ./lima --help
#

# Get the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Check if lima_cli.sh exists in scripts subdirectory
if [ ! -f "$SCRIPT_DIR/scripts/lima_cli.sh" ]; then
    echo "Error: scripts/lima_cli.sh not found in $SCRIPT_DIR"
    echo "Expected directory structure:"
    echo "  lima/"
    echo "  ├── lima           (this wrapper)"
    echo "  └── scripts/"
    echo "      └── lima_cli.sh"
    exit 1
fi

# Run the Lima CLI
bash "$SCRIPT_DIR/scripts/lima_cli.sh" "$@"
